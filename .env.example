# Copiar a .env y completar. NUNCA subir el .env real (está en .gitignore).
ANTHROPIC_API_KEY=your_anthropic_api_key
ZAMMAD_URL=https://your-zammad-server
ZAMMAD_TOKEN=your_api_token

# Opcional: modelo a usar (default claude-opus-4-8).
ZAMMAD_AGENT_MODEL=claude-opus-4-8

# Verificación TLS. Por defecto true (secure-by-default).
# Poner en false SOLO para instancias internas con certificado autofirmado.
ZAMMAD_VERIFY_SSL=true
